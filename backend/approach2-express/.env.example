# Approach 2 – Express backend environment variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173

# Admin email – all enquiry notifications land here
ADMIN_EMAIL=newkidspre@gmail.com

# ─── Gmail SMTP (recommended) ───────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail" → copy the 16-char code below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=newkidspre@gmail.com
SMTP_PASS=woutenggvtonckbo

# ─── Outlook/Hotmail (alternative) ──────────────────────────────────────────
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=newkidspre@outlook.com
# SMTP_PASS=your-password

# ─── Custom SMTP e.g. Zoho, SendGrid (alternative) ──────────────────────────
# SMTP_HOST=smtp.zoho.in
# SMTP_PORT=465
# SMTP_SECURE=true
