# Approach 2 – Express backend environment variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173

# Admin email (receives all enquiry notifications)
ADMIN_EMAIL=admin@littlestars.in

# SMTP Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# For Outlook/Hotmail:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587

# For custom SMTP (e.g. Zoho, SendGrid):
# SMTP_HOST=smtp.zoho.in
# SMTP_PORT=465
# SMTP_SECURE=true
